{
    "name": "sigilweaver-blog",
    "compatibility_date": "2024-11-26",
    "assets": {
        "directory": "./build"
    },
    "routes": [
        {
            "pattern": "sigilweaver.app/blog",
            "zone_name": "sigilweaver.app"
        },
        {
            "pattern": "sigilweaver.app/blog/*",
            "zone_name": "sigilweaver.app"
        }
    ]
}
